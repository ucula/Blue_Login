{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["bun"]
  },
  "include": [
    "server.ts",
    "src/**/*.ts",
    "src/services/user/auth/verifyValue.ts",
    "../front-end/src/types/redirectLogin.ts"
  ],
  "exclude": ["node_modules"]
}
