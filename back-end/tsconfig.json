{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["bun"],
    "jsx": "react-jsx"
  },
  "include": ["server.ts", "preview-email.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
